# Скопируйте этот файл в .env и заполните настоящие ключи.
# Не коммитьте .env.
#
# cp .env.example .env

# OpenRouter API key для live-вызовов модели:
# https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Tavily API key для live web search:
# https://app.tavily.com/
TAVILY_API_KEY=

# Модель OpenRouter по умолчанию.
OPENROUTER_MODEL=z-ai/glm-5.1
OPENROUTER_FALLBACK_MODEL=openrouter/auto

# Строго бесплатный вариант OpenRouter, если нужен эксперимент без списаний:
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-120b:free

# Phoenix/OpenTelemetry.
# Блокнот может поднять локальный Phoenix сам; standalone baseline подключается к уже запущенному collector.
# PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_PORT=6006
PHOENIX_GRPC_PORT=4317
PHOENIX_WORKING_DIR=.phoenix

# Раскомментируйте, чтобы принудительно отключить Phoenix.
# DISABLE_PHOENIX=1
